# Postgres connection string (Railway provides this automatically when you add a Postgres plugin)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/cardscanpro

# Anthropic API key for Claude Sonnet 4.5 (card photo analysis)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Port the server listens on (Railway sets this automatically)
PORT=5000

# Node environment — set to "production" on Railway
NODE_ENV=production
